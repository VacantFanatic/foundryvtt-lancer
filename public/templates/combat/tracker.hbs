<ol class="combat-tracker plain">
  {{#each turns}}
    <li class="combatant {{ css }}" data-combatant-id="{{ id }}" data-action="activateCombatant">
      {{#if targetSummary}}
        <div class="combatant-targets minor" data-tooltip="{{ localize 'lancer.combat-tracker.your-targets' }}">
          <i class="fas fa-crosshairs" aria-hidden="true"></i>
          <span>{{targetSummary}}</span>
        </div>
      {{/if}}

      {{!-- Image --}}
      <img class="token-image" src="{{ img }}" alt="{{ name }}" loading="lazy">

      {{!-- Name & Controls --}}
      <div class="token-name">
        <strong class="name">{{name}}</strong>
        <div class="combatant-controls">
          {{#if @root.user.isGM}}
            <button
              type="button"
              class="inline-control combatant-control icon fa-solid fa-eye-slash {{#if hidden}}active{{/if}}"
              data-action="toggleHidden"
              data-tooltip="{{ localize 'COMBAT.ToggleVis' }}"
              aria-label='{{ localize "COMBAT.ToggleVis" }}'
            >
            </button>
            <button
              type="button"
              class="inline-control combatant-control icon fa-solid fa-skull {{#if isDefeated}}active{{/if}}"
              data-action="toggleDefeated"
              data-tooltip="{{ localize 'COMBAT.ToggleDead' }}"
              aria-label='{{ localize "COMBAT.ToggleDead" }}'
            >
            </button>
          {{/if}}
          {{#if canPing}}
            <button
              type="button"
              class="inline-control combatant-control icon fa-solid fa-bullseye-arrow"
              data-action="pingCombatant"
              data-tooltip="{{ localize 'COMBAT.PingCombatant' }}"
              aria-label='{{ localize "COMBAT.PingCombatant" }}'
            >
            </button>
          {{/if}}
          {{#unless @root.user.isGM}}
            <button
              type="button"
              class="inline-control combatant-control icon fa-solid fa-arrows-to-eye"
              data-action="panToCombatant"
              data-tooltip="{{ localize 'COMBAT.PanToCombatant' }}"
              aria-label='{{ localize "COMBAT.PanToCombatant" }}'
            >
            </button>
          {{/unless}}
          <span class="activations" data-tooltip="{{ localize 'lancer.Actor.FIELDS.activations.label' }}">
            <i class="cci cci-activate"></i>
            <span>{{this.activations}}</span>
          </span>
          {{#if canTarget}}
            <button
              type="button"
              class="inline-control combatant-control icon fa-solid fa-crosshairs {{#if isTargeted}}active{{/if}}"
              data-action="toggleCombatantTarget"
              data-tooltip="{{ localize 'lancer.combat-tracker.toggle-target' }}"
              aria-label='{{ localize "lancer.combat-tracker.toggle-target" }}'
            >
            </button>
          {{/if}}
          <div class="token-effects" data-tooltip="{{ effects.tooltip }}">
            {{#each effects.icons}}
              <img class="token-effect" src="{{ img }}" alt="{{ name }}">
            {{/each}}
          </div>
        </div>
      </div>

      {{!-- Resource --}}
      {{#if resource includeZero=true}}
        <div class="token-resource">
          <span class="resource">{{resource}}</span>
        </div>
      {{/if}}

      {{!-- Activation Buttons --}}
      <div class="token-initiative">
        {{#each buttons}}
          <button
            type="button"
            class="icon {{ icon }}"
            data-action="{{ action }}"
            data-tooltip="{{ localize (concat 'LANCERINITIATIVE.COMBAT.' action) }}"
            aria-label='{{ localize (concat "LANCERINITIATIVE.COMBAT." action) }}'
          >
          </button>
        {{/each}}
      </div>
    </li>
  {{/each}}
</ol>
