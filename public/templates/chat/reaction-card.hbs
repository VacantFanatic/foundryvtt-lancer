<div class="card clipped-bot lancer-chat-card">
  <div class="lancer-header lancer-reaction">// {{upper-case title}} //</div>

  <div class="card clipped lancer-chat-card-body">
    <div class="flexcol lancer-chat-effect-col">
      <span class="medium flexrow">{{localize "lancer.chat-card.label.trigger"}}</span>
      <div class="effect-text flexrow lancer-chat-effect-row">
        {{{trigger}}}
      </div>
      <span class="medium flexrow">{{localize "lancer.chat-card.label.effect"}}</span>
      <div class="effect-text flexrow lancer-chat-effect-row">
        {{{effect}}}
      </div>
    </div>
    {{{tag-list "tags"}}}
  </div>
</div>
